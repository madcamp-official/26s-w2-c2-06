# Gemini API (기능 4 로드맵 생성이 사용). 하드코딩 금지, 값 커밋 금지.
# Google AI Studio(aistudio.google.com)에서 발급 — docs/setup/API_KEY_SETUP.md 참고.
#
# ※ 기능 3(리서치)은 v0.4에서 검색 백엔드를 소스 API(Semantic Scholar/arXiv, 키 불필요)로
#    전환해 Gemini가 필요 없다. 따라서 v0.3의 "키 기능별 분리" 정책은 사실상 불필요해졌고,
#    현재는 단일 GEMINI_API_KEY만 사용한다(기능 4). 상세: 계약 v0.5 §6.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# PostgreSQL + pgvector (psycopg3 드라이버 사용 -> postgresql+psycopg:// 스킴)
# 로컬(venv/uv)로 직접 실행할 때는 localhost 사용.
# docker-compose로 실행할 때는 이 값이 app 서비스의 DATABASE_URL로 자동 오버라이드됨(docker-compose.yml 참고).
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ai_champion

# docker-compose가 db 컨테이너를 띄울 때 사용하는 값 (위 DATABASE_URL과 자격증명 맞출 것)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ai_champion

# Redis
# docker-compose로 실행할 때는 redis 서비스로 자동 오버라이드됨.
REDIS_URL=redis://localhost:6379/0

# Notion API — 여러 사용자가 각자 자기 워크스페이스로 발행받을 수 있어야 해서
# Internal Integration이 아니라 Public Integration(OAuth)을 사용한다.
# notion.so/my-integrations 에서 "Public" 타입으로 만들고, redirect URI를 아래
# NOTION_OAUTH_REDIRECT_URI와 정확히 똑같이 등록해야 한다.
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:8000/notion/callback

# ML 서버 (camp10, 임베딩/RAG 서빙)
ML_SERVER_HOST=172.10.5.171
